load("//tools:defaults2.bzl", "ts_project", "jasmine_test")

ts_project(
    name = "patched_init",
    testonly = True,
    srcs = [
        "enable-clock-patch.ts",
        "patched.init.ts",
    ],
    deps = [
        "//packages/zone.js/test:node_entry_point_rjs",
    ],
)

ts_project(
    name = "test_patched_lib",
    testonly = True,
    srcs = [
        "fake-async-patched-clock.spec.ts",
    ],
    deps = [
        "//packages/zone.js/lib:zone_d_ts_rjs",
    ],
)

ts_project(
    name = "unpatched_init",
    testonly = True,
    srcs = [
        "unpatched.init.ts",
    ],
    deps = [
        "//packages/zone.js/test:node_entry_point_rjs",
    ],
)

ts_project(
    name = "test_unpatched_lib",
    testonly = True,
    srcs = [
        "fake-async-unpatched-clock.spec.ts",
    ],
    deps = [
        "//packages/zone.js/lib:zone_d_ts_rjs",
    ],
)

jasmine_test(
    name = "test_patched",
    data = [
        ":patched_init_rjs",
        ":test_patched_lib",
    ],
    
    fixed_args = [
        "--require={root}/packages/zone.js/test/zone-spec/clock-tests/patched.init.js",
    ],
)

jasmine_test(
    name = "test_unpatched",
    data = [
        ":unpatched_init_rjs",
        ":test_unpatched_lib_rjs",
    ],
    fixed_args = [
        "--require={root}/packages/zone.js/test/zone-spec/clock-tests/unpatched.init.js",
    ],
)